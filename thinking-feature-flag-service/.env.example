# Copy to .env for local development:  cp .env.example .env
#
# Every value the service reads is here. Nothing is hardcoded and nothing is read from
# a config file at runtime, so the GCP deployment differs only in where these come
# from: Cloud Run injects DATABASE_URL and ADMIN_API_KEY from Secret Manager, and the
# rest as plain environment variables on the revision. No code changes between the two.

# --- Runtime -------------------------------------------------------------------
APP_ENV=local              # local | development | staging | production
LOG_LEVEL=DEBUG            # local uses human-readable logs; anything else emits JSON
PORT=8080
GCP_PROJECT_ID=            # only used to qualify the trace field for Cloud Logging

# --- Datastores ----------------------------------------------------------------
# Matches docker-compose.dev.yml. On Cloud Run with the Cloud SQL connector this
# becomes a unix socket and comes from Secret Manager:
#   postgresql+asyncpg://USER:PASS@/flagsvc?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=postgresql+asyncpg://flagsvc:flagsvc@localhost:5433/flagsvc
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_ECHO=false

REDIS_URL=redis://localhost:6380/0

# --- Auth ----------------------------------------------------------------------
# Bootstrap credential for POST /api/v1/tenants only. A tenant cannot authenticate its
# own creation, so this endpoint needs an operator credential. In production this comes
# from Secret Manager and is never a literal like the one below.
ADMIN_API_KEY=dev-admin-key-change-me

# --- Cache ---------------------------------------------------------------------
# Caches the compiled flag set per (tenant, environment), not per user. Writes
# invalidate immediately, so the TTL is a backstop against a missed invalidation rather
# than the primary freshness mechanism — it bounds how long a killed flag could stay
# live if Redis were unreachable during the DELETE.
CACHE_TTL_SECONDS=300
CACHE_ENABLED=true

# --- Rate limiting -------------------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=1000
